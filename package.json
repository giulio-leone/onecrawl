{
  "name": "onecrawl-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "build": "cd packages/onecrawl-rust && cargo build --workspace",
    "test": "cd packages/onecrawl-rust && cargo test --workspace",
    "clippy": "cd packages/onecrawl-rust && cargo clippy --workspace",
    "build:napi": "cd packages/onecrawl-rust/bindings/napi && npm run build",
    "build:release": "cd packages/onecrawl-rust && cargo build --release -p onecrawl-cli-rs"
  }
}
