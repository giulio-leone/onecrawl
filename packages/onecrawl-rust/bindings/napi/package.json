{
  "name": "@onecrawl/native",
  "version": "0.1.0",
  "description": "High-performance browser automation — Rust core via NAPI-RS",
  "main": "index.js",
  "types": "index.d.ts",
  "author": "Giulio Leone",
  "license": "MIT",
  "homepage": "https://github.com/giulio-leone/onecrawl",
  "repository": {
    "type": "git",
    "url": "https://github.com/giulio-leone/onecrawl.git"
  },
  "keywords": [
    "browser",
    "automation",
    "cdp",
    "scraping",
    "stealth",
    "onecrawl",
    "napi"
  ],
  "engines": {
    "node": ">= 18"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "napi build --release --platform",
    "build:debug": "napi build",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "node --test test/"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  },
  "napi": {
    "binaryName": "onecrawl",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc"
    ]
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ]
}
